{
  "name": "unity-mcp",
  "version": "1.0.0",
  "description": "Unified MCP server for Unity Editor integration and Unity knowledge base search",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "unity-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "clean": "rimraf build"
  },
  "keywords": [
    "mcp",
    "unity",
    "unity3d",
    "game",
    "engine",
    "rag",
    "ai",
    "assistant"
  ],
  "author": {
    "name": "Joel Wehr",
    "email": "joel.wehr@gmail.com",
    "url": "https://github.com/joel-wehr"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joel-wehr/unity-mcp.git"
  },
  "homepage": "https://github.com/joel-wehr/unity-mcp#readme",
  "bugs": {
    "url": "https://github.com/joel-wehr/unity-mcp/issues"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.24.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
